{
  "version": "1.0.0",
  "updatedAt": "2026-03-22",
  "tier": "pro",
  "description": "ClawGuard Pro — 104 patterns with monthly updates",
  "patterns": [
    {
      "id": "CG-026",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Multiple zero-width Unicode chars — likely hidden text injection",
      "pattern": "[\\u200B\\u200C\\u200D\\uFEFF]{2,}|[\\u200B\\u200C\\u200D\\uFEFF][a-zA-Z]",
      "flags": "i"
    },
    {
      "id": "CG-027",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Cyrillic homoglyph substitution — Latin lookalike attack",
      "pattern": "[\\u0400-\\u04FF]",
      "flags": "i"
    },
    {
      "id": "CG-028",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Multi-language instruction override (ES/FR/DE/PT)",
      "pattern": "ignora\\s+las\\s+instrucciones|ignorez\\s+les\\s+instructions|ignoriere\\s+(alle\\s+)?anweisungen|ignore\\s+as\\s+instru\\u00E7\\u00F5es",
      "flags": "i"
    },
    {
      "id": "CG-029",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "LLM template token injection (INST/SYS/im_start tags)",
      "pattern": "\\[INST\\]|<<SYS>>|<\\|im_start\\||<\\|system\\||\\[\\[system\\]\\]|<\\|im_end\\|>",
      "flags": "i"
    },
    {
      "id": "CG-030",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Markdown code block used to smuggle system instructions",
      "pattern": "```\\s*(system|prompt|instructions?|override|jailbreak)\\s*\\n",
      "flags": "i"
    },
    {
      "id": "CG-031",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Base64-encoded instructions hidden in comments",
      "pattern": "(?:\\/\\/|\\/\\*|<!--|#|<!--)\\s*[A-Za-z0-9+\\/]{30,}={0,2}\\s*(?:-->|\\*\\/)?$",
      "flags": "i"
    },
    {
      "id": "CG-032",
      "category": "advanced_prompt_injection",
      "severity": "MEDIUM",
      "description": "HTML entity encoding to obfuscate injected keywords",
      "pattern": "(?:&#[0-9]{2,4};){3,}|(?:&#x[0-9a-fA-F]{2,4};){3,}",
      "flags": "i"
    },
    {
      "id": "CG-033",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Fake user/human message injection framing",
      "pattern": "\\[(?:user|human|you|customer)\\]\\s*:|<user>|<human>|\\bHuman:\\s|\\bUser:\\s.*ignore",
      "flags": "i"
    },
    {
      "id": "CG-034",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Continuation/completion attack — forces dangerous output",
      "pattern": "(?:complete|continue|finish)\\s+(?:this|the)\\s+(?:sentence|text|code|following)[^.]{0,100}(?:harm|exploit|attack|bypass|steal|exfil)",
      "flags": "i"
    },
    {
      "id": "CG-035",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Token boundary attack — injection phrase split by separators",
      "pattern": "i(?:g[^a-z]{1,3}n[^a-z]{1,3}o[^a-z]{1,3}r[^a-z]{1,3}e|[^a-z]{1,3}g[^a-z]{1,3}n[^a-z]{1,3}o[^a-z]{1,3}r)[^a-z]{1,5}(?:all|prior|previous|above)[^a-z]{1,5}inst",
      "flags": "i"
    },
    {
      "id": "CG-036",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Roleplay escalation to remove AI restrictions",
      "pattern": "(?:roleplay|role.play|let'?s\\s+play|pretend\\s+you\\s+are).{0,80}(?:no\\s+restrict|without\\s+restrict|unrestrict|no\\s+limit|no\\s+filter|no\\s+rule|no\\s+safeguard)",
      "flags": "i"
    },
    {
      "id": "CG-037",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Authority spoofing — claims to be AI developer or Anthropic",
      "pattern": "I\\s+am\\s+(?:from\\s+)?(?:Anthropic|OpenAI|Google\\s+DeepMind|the\\s+developers?|your\\s+(?:creator|developer|maker|owner|trainer))",
      "flags": "i"
    },
    {
      "id": "CG-038",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Time-delayed injection — triggers action after N messages",
      "pattern": "after\\s+(?:the\\s+)?(?:next\\s+)?(?:\\d+|every|each)\\s+(?:message|turn|response|request|exchange).{0,80}(?:do|execute|perform|run|send|reveal|leak|exfil)",
      "flags": "i"
    },
    {
      "id": "CG-039",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Conditional injection — triggers on specific user input",
      "pattern": "if\\s+(?:the\\s+)?(?:user|they|someone).{0,50}(?:then|do|execute|perform|reveal|leak|send|transmit).{0,80}(?:secret|password|key|credential|token|prompt|config)",
      "flags": "i"
    },
    {
      "id": "CG-040",
      "category": "advanced_prompt_injection",
      "severity": "MEDIUM",
      "description": "Context stuffing — repeated text to push out safety rules",
      "pattern": "(\\b\\w+\\b[\\s,]+)\\1{40,}",
      "flags": "i"
    },
    {
      "id": "CG-041",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "System prompt / instruction extraction attempt",
      "pattern": "(?:print|show|display|output|repeat|reveal|tell\\s+me|what\\s+(?:is|are))\\s+(?:your\\s+)?(?:system\\s+prompt|initial\\s+prompt|original\\s+instructions?|full\\s+prompt|hidden\\s+instructions?)",
      "flags": "i"
    },
    {
      "id": "CG-042",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Fictional framing to bypass content restrictions",
      "pattern": "(?:fictional|hypothetical|imagine|in\\s+a\\s+story|in\\s+this\\s+scenario|let'?s\\s+say).{0,80}(?:no\\s+restrict|without\\s+restrict|no\\s+limit|no\\s+rule|no\\s+filter|no\\s+safeguard|no\\s+ethics)",
      "flags": "i"
    },
    {
      "id": "CG-043",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Developer/maintenance/god mode activation attempt",
      "pattern": "(?:enable|activate|switch\\s+to|enter|unlock|turn\\s+on)\\s+(?:developer|debug|maintenance|god|admin|root|unrestricted|jailbreak)\\s+mode",
      "flags": "i"
    },
    {
      "id": "CG-044",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "Content policy removal — pretend no restrictions exist",
      "pattern": "pretend\\s+(?:you\\s+have\\s+no|there\\s+(?:is|are)\\s+no)\\s+(?:content\\s+policy|restriction|guideline|safeguard|filter|ethic|moral|rule|limit)",
      "flags": "i"
    },
    {
      "id": "CG-045",
      "category": "advanced_prompt_injection",
      "severity": "HIGH",
      "description": "YAML/JSON formatted system prompt injection",
      "pattern": "system_prompt\\s*:|\"role\"\\s*:\\s*\"system\"|role:\\s*system\\b|\"content\"\\s*:\\s*\"(?:ignore|override|forget|disregard)",
      "flags": "i"
    },
    {
      "id": "CG-046",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Writing to cron directories for scheduled persistence",
      "pattern": "\\/etc\\/cron\\.(?:d|daily|hourly|weekly|monthly)|crontab\\s+-[elu]|writeFile.*crontab|appendFile.*crontab",
      "flags": "i"
    },
    {
      "id": "CG-047",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Modifying shell RC files for persistent code execution",
      "pattern": "(?:writeFile|appendFile|>>)[^\\n]*\\.(?:bashrc|zshrc|bash_profile|profile|bash_login|zprofile|zlogin|fish_config)\\b",
      "flags": "i"
    },
    {
      "id": "CG-048",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "macOS LaunchAgent/LaunchDaemon persistence",
      "pattern": "Library\\/LaunchAgents|Library\\/LaunchDaemons|\\/System\\/Library\\/LaunchDaemons|\\.plist.*launchd",
      "flags": "i"
    },
    {
      "id": "CG-049",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Windows Registry Run key modification for autostart",
      "pattern": "HKEY_(?:CURRENT_USER|LOCAL_MACHINE)\\\\.*\\\\Run\\b|reg\\s+add.*\\\\Run\\b|CurrentVersion\\\\Run|HKCU\\\\.*Run\\b",
      "flags": "i"
    },
    {
      "id": "CG-050",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Windows scheduled task creation for persistence",
      "pattern": "schtasks\\s+\\/create|New-ScheduledTask|Register-ScheduledTask|SchTasks\\.exe.*\\/create",
      "flags": "i"
    },
    {
      "id": "CG-051",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Modifying SSH authorized_keys for backdoor access",
      "pattern": "\\.ssh\\/authorized_keys|authorized_keys.*(?:write|append|>>)|(?:writeFile|appendFile|>>).*authorized_keys",
      "flags": "i"
    },
    {
      "id": "CG-052",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Modifying /etc/hosts — DNS hijacking or redirection",
      "pattern": "(?:writeFile|appendFile|>>).*\\/etc\\/hosts|\\/etc\\/hosts.*(?:writeFile|appendFile)|echo.*>>\\/etc\\/hosts",
      "flags": "i"
    },
    {
      "id": "CG-053",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Silent global npm package installation",
      "pattern": "npm\\s+(?:install|i)\\s+(?:[^\\n]*\\s)?-g\\b|npm\\s+-g\\s+(?:install|i)\\b",
      "flags": "i"
    },
    {
      "id": "CG-054",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Creating hidden dotfiles/directories for concealed persistence",
      "pattern": "(?:writeFile|mkdirSync|mkdir)\\s*\\([^)]*[\\/][.][a-zA-Z0-9_]{2,}|mkdir\\s+-p?\\s+~\\/\\.[a-zA-Z]",
      "flags": "i"
    },
    {
      "id": "CG-055",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "PATH manipulation written to shell config files",
      "pattern": "export\\s+PATH=.*:\\$PATH.*(?:bashrc|zshrc|profile|bash_profile)|(?:bashrc|zshrc|profile).*export\\s+PATH=",
      "flags": "i"
    },
    {
      "id": "CG-056",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Creating system startup scripts in init.d or rc.local",
      "pattern": "\\/etc\\/init\\.d\\/[a-zA-Z]|\\/etc\\/rc\\.local|\\/etc\\/rc[0-9]\\.d\\/|update-rc\\.d\\s+",
      "flags": "i"
    },
    {
      "id": "CG-057",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Tampering with openclaw.json config for malicious settings",
      "pattern": "(?:writeFile|appendFile).*openclaw\\.json|openclaw\\.json.*(?:writeFile|appendFile)|JSON\\.stringify.*openclaw",
      "flags": "i"
    },
    {
      "id": "CG-058",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Injecting code into existing scripts via file append",
      "pattern": "appendFile\\s*\\([^)]*\\.(?:sh|bash|py|rb|pl|ps1)\\b|>>[^\\n]*\\.(?:sh|bash|py|rb|pl|ps1)\\b",
      "flags": "i"
    },
    {
      "id": "CG-059",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Creating/modifying git hooks for code execution on commits",
      "pattern": "\\.git\\/hooks\\/(?:pre-commit|post-commit|pre-push|post-merge|pre-receive|post-receive|prepare-commit-msg|post-checkout)",
      "flags": "i"
    },
    {
      "id": "CG-060",
      "category": "persistence_backdoor",
      "severity": "HIGH",
      "description": "Hijacking npm lifecycle scripts in package.json",
      "pattern": "\"(?:postinstall|preinstall|prepare|prepack|postpack)\"\\s*:\\s*\"[^\"]{10,}\"",
      "flags": "i"
    },
    {
      "id": "CG-061",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading browser localStorage/sessionStorage data",
      "pattern": "localStorage\\.getItem|sessionStorage\\.getItem|window\\.localStorage\\b|Object\\.keys.*localStorage",
      "flags": "i"
    },
    {
      "id": "CG-062",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Accessing browser cookie database files directly",
      "pattern": "(?:Google|Chrome|Chromium)\\/.*Cookies\\b|Firefox.*cookies\\.sqlite|AppData.*Chrome.*Cookies|Library.*Chrome.*Cookies|Mozilla.*cookies\\.sqlite",
      "flags": "i"
    },
    {
      "id": "CG-063",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading macOS Keychain credentials",
      "pattern": "security\\s+find-(?:generic|internet|certificate)-password|SecKeychainFind|SecItemCopyMatching.*kSecClass|\\bkeychain\\b.*(?:read|dump|extract|export)",
      "flags": "i"
    },
    {
      "id": "CG-064",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Accessing Windows Credential Manager stored secrets",
      "pattern": "cmdkey\\s+\\/list|CredRead\\s*\\(|CredEnumerate\\s*\\(|vaultcmd\\s+\\/listcreds|Windows\\s+Credential\\s+Manager",
      "flags": "i"
    },
    {
      "id": "CG-065",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading SSH private key files",
      "pattern": "readFile.*\\.ssh\\/id_(?:rsa|ed25519|ecdsa|dsa)\\b|\\.ssh\\/id_(?:rsa|ed25519|ecdsa|dsa).*readFile|cat\\s+.*\\.ssh\\/id_",
      "flags": "i"
    },
    {
      "id": "CG-066",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Exporting or listing GPG secret keys",
      "pattern": "gpg\\s+--export-secret|gpg\\s+--list-secret-keys|\\.gnupg\\/secring|gpg\\s+-a\\s+--export|gpg\\s+--armor.*--export-secret",
      "flags": "i"
    },
    {
      "id": "CG-067",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading git credential files with stored passwords",
      "pattern": "readFile.*\\.git-credentials|cat\\s+.*\\.git-credentials|\\.git-credentials.*readFile|git\\s+config\\s+--(?:global|list).*credential",
      "flags": "i"
    },
    {
      "id": "CG-068",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading npm auth tokens from .npmrc",
      "pattern": "readFile.*\\.npmrc|\\.npmrc.*readFile|cat\\s+.*\\.npmrc|_authToken\\s*=|npm_token",
      "flags": "i"
    },
    {
      "id": "CG-069",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading AWS credentials and secret access keys",
      "pattern": "readFile.*\\.aws\\/(?:credentials|config)|cat\\s+.*\\.aws\\/credentials|aws_secret_access_key|aws_access_key_id",
      "flags": "i"
    },
    {
      "id": "CG-070",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Accessing Docker registry credentials config",
      "pattern": "\\.docker\\/config\\.json|readFile.*docker.*config\\.json|docker.*auths.*registry|dockerconfigjson",
      "flags": "i"
    },
    {
      "id": "CG-071",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading VS Code stored tokens or global state",
      "pattern": "Code\\/User\\/(?:settings|keybindings|globalStorage)|vscode.*(?:token|secret|auth)|globalStorage.*vscode|User\\/globalStorage",
      "flags": "i"
    },
    {
      "id": "CG-072",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Accessing Telegram Desktop session files (tdata)",
      "pattern": "Telegram\\s+Desktop\\/tdata|tdata\\/[A-Z0-9]{8}|telegram.*session.*(?:read|copy|exfil)|Telegram.*\\.session\\b",
      "flags": "i"
    },
    {
      "id": "CG-073",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading WhatsApp message databases",
      "pattern": "WhatsApp\\/Databases|msgstore\\.db|whatsapp.*\\.sqlite|wa\\.db\\b|WhatsApp.*readFile",
      "flags": "i"
    },
    {
      "id": "CG-074",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Accessing macOS Calendar or Contacts databases",
      "pattern": "Calendar\\/v[0-9]+\\.db|AddressBook-v[0-9]+\\.abcddb|Library\\/Calendars|Library\\/Application\\s+Support\\/AddressBook",
      "flags": "i"
    },
    {
      "id": "CG-075",
      "category": "data_harvesting",
      "severity": "HIGH",
      "description": "Reading browser saved password database files",
      "pattern": "Login\\s+Data\\b|key4\\.db\\b|logins\\.json\\b|signons\\.sqlite\\b|readFile.*Login\\s+Data|Login\\s+Data.*readFile",
      "flags": "i"
    },
    {
      "id": "CG-NEW-001",
      "category": "auto_registration",
      "severity": "HIGH",
      "description": "Auto-creates accounts on external services via POST",
      "pattern": "curl.*-X.*POST.*(create-account|register|signup|new-user)",
      "flags": "i"
    },
    {
      "id": "CG-NEW-002",
      "category": "exfiltration",
      "severity": "MEDIUM",
      "description": "API key exposed as URL query parameter",
      "pattern": "https?:\\/\\/[^\\s\"']+\\?[a-z_-]*(?:key|token|secret)=[a-zA-Z0-9]{10,}",
      "flags": "i"
    },
    {
      "id": "CG-NEW-003",
      "category": "autonomous_action",
      "severity": "MEDIUM",
      "description": "Sends emails autonomously without user confirmation",
      "pattern": "transporter\\.sendMail|smtp.*\\.send\\(|nodemailer.*send",
      "flags": "i"
    },
    {
      "id": "CG-NEW-004",
      "category": "exfiltration",
      "severity": "HIGH",
      "description": "Sends local file contents via curl POST to external URL",
      "pattern": "curl.*-d\\s+@|curl.*--data\\s+@",
      "flags": "i"
    },
    {
      "id": "CG-076",
      "category": "supply_chain_typosquatting",
      "severity": "HIGH",
      "description": "Typosquatted package names mimicking popular npm packages",
      "pattern": "require\\s*\\(\\s*['\"](?:lod[a4]sh|reac[t7]|expre[s5]{2}|mongoo[s5]e|axio[s5]|webpa[c4]k|moment[j1]s|lodas[hн]|reacts?-dom|expresss)['\"]\\s*\\)",
      "flags": "i"
    },
    {
      "id": "CG-077",
      "category": "supply_chain_dep_confusion",
      "severity": "HIGH",
      "description": "Dependency confusion — requiring internal-scoped packages from public registry",
      "pattern": "require\\s*\\(\\s*['\"]@(?:internal|private|corp|company|enterprise)\\/.+?['\"]\\s*\\)|['\"]@(?:internal|private|corp|company)\\/[a-z0-9_-]+['\"]\\s*:\\s*['\"]\\^?[0-9]",
      "flags": "i"
    },
    {
      "id": "CG-078",
      "category": "supply_chain_update_hijack",
      "severity": "HIGH",
      "description": "Auto-update mechanism pulling from untrusted or dynamic source",
      "pattern": "(?:auto.?update|self.?update|force.?upgrade|silentUpdate)\\s*\\([^)]*(?:https?:\\/\\/(?!registry\\.npmjs\\.org|github\\.com\\/|raw\\.githubusercontent\\.com\\/)[a-z0-9.-]+)",
      "flags": "i"
    },
    {
      "id": "CG-079",
      "category": "supply_chain_version_rollback",
      "severity": "HIGH",
      "description": "Forcing installation of older, potentially vulnerable package versions",
      "pattern": "npm\\s+install\\s+[a-z0-9@/_-]+@(?:0\\.[0-9]+\\.[0-9]+|[0-9]+\\.[0-9]+\\.[0-9]+-(?:alpha|beta|rc)\\.[0-9]+)\\b.*?(?:--save|--force|--legacy-peer-deps)",
      "flags": "i"
    },
    {
      "id": "CG-080",
      "category": "supply_chain_checksum_bypass",
      "severity": "HIGH",
      "description": "Skipping package integrity or checksum verification",
      "pattern": "(?:--ignore-scripts|skipIntegrity|disableIntegrity|skip.?checksum|integrity.?(?:false|null|undefined|skip)|--no-package-lock|verif(?:y|ication).?(?:false|disabled|skip))",
      "flags": "i"
    },
    {
      "id": "CG-081",
      "category": "supply_chain_postinstall_script",
      "severity": "HIGH",
      "description": "Malicious postinstall script executing shell commands or downloads",
      "pattern": "\"(?:postinstall|preinstall|install)\"\\s*:\\s*\"[^\"]*(?:curl|wget|bash|sh\\s|exec|eval|node\\s+-e|python)[^\"]*\"",
      "flags": "i"
    },
    {
      "id": "CG-082",
      "category": "supply_chain_trojanized_helper",
      "severity": "HIGH",
      "description": "Helper/utility module that secretly spawns child processes",
      "pattern": "(?:helper|util|utils|tool|adapter|plugin|wrapper)\\s*=\\s*require\\s*\\([^)]+\\)[\\s\\S]{0,200}?\\.(?:exec|spawn|execSync|spawnSync|fork)\\s*\\(",
      "flags": "i"
    },
    {
      "id": "CG-083",
      "category": "supply_chain_shadow_dep",
      "severity": "MEDIUM",
      "description": "Loading packages not listed in package.json via non-standard require paths",
      "pattern": "(?:__non_webpack_require__|global\\.require|globalThis\\.require|\\beval\\b.*?require|require\\.main\\.require)\\s*\\(|process\\.mainModule\\.require\\s*\\(",
      "flags": "i"
    },
    {
      "id": "CG-084",
      "category": "supply_chain_registry_confusion",
      "severity": "HIGH",
      "description": "npm registry redirected to attacker-controlled private registry",
      "pattern": "(?:registry\\s*=\\s*https?:\\/\\/(?!registry\\.npmjs\\.org|registry\\.yarnpkg\\.com)|--registry\\s+https?:\\/\\/(?!registry\\.npmjs\\.org)|npmrc.*?registry\\s*=\\s*https?:\\/\\/[a-z0-9.-]{4,}(?!npmjs))",
      "flags": "i"
    },
    {
      "id": "CG-085",
      "category": "supply_chain_build_tool_injection",
      "severity": "HIGH",
      "description": "Compromised webpack, babel, or rollup config executing shell commands",
